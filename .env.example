# =============================================================================
# SC4S Environment Configuration
# =============================================================================
# Copy this file to .env and update with your Splunk HEC details
# =============================================================================

# --- Splunk HEC Configuration (REQUIRED) ---
SC4S_DEST_SPLUNK_HEC_DEFAULT_URL=https://splunk-hec.company.com:8088
SC4S_DEST_SPLUNK_HEC_DEFAULT_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SC4S_DEST_SPLUNK_HEC_DEFAULT_TLS_VERIFY=no

# --- SC4S Source Listeners ---
# Enable/disable specific listeners
SC4S_LISTEN_DEFAULT_TCP_PORT=514
SC4S_LISTEN_DEFAULT_UDP_PORT=514
SC4S_LISTEN_DEFAULT_RFC6587_PORT=601
SC4S_LISTEN_DEFAULT_TLS_PORT=6514

# --- Performance Tuning ---
SC4S_SOURCE_LISTEN_UDP_SOCKETS=4
SC4S_DEST_SPLUNK_HEC_WORKERS=20

# --- Timezone (for sources that don't include TZ) ---
SC4S_DEFAULT_TIMEZONE=America/New_York

# --- Debug ---
# SC4S_SOURCE_STORE_RAWMSG=yes
# SC4S_DEBUG_CONTAINER=yes
